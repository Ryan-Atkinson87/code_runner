# Code Runner — required environment variables
# Copy to .env and fill in real values. Never commit .env.

GITHUB_PAT=
ANTHROPIC_API_KEY=
NOTION_TOKEN=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
AUTH_PASSWORD_HASH=

# Shared secret bearer token for the agent-runner executor's internal RPC
# surface (bash-exec / text-editor endpoints, Spec §7.1/§7.2). agent-runner
# rejects every request with 401 if this doesn't match, and 503 if unset.
# orchestrator-api will send this same value once it calls the executor (#258).
AGENT_RUNNER_TOKEN=

# Optional (enable email notifications in project.yaml to use)
# RESEND_API_KEY=
# RESEND_TO_ADDRESS=

# Target project directory (absolute host path). Mounted read-write into
# orchestrator-api at /workspace — the Claude adapter's tool calls still run
# as subprocess calls inside that container today. Also mounted read-write
# into agent-runner at the same path: agent-runner now has a real bash/
# text-editor executor service listening on it (#256), but orchestrator-api
# doesn't call it yet — that swap is #258.
# CODE_RUNNER_PROJECT_DIR=

# orchestrator-api composition root — set all three to boot with real
# dependencies wired (RunController, GitHubClient, UsageMonitor, etc).
# Leave unset to run with no project bound (routes needing them 500 until set).
# project.yaml and execution-profile.yaml are expected to live inside the
# CODE_RUNNER_PROJECT_DIR mount (i.e. under /workspace); the SQLite DB lives
# on the orchestrator-api-data volume (/data), which persists across restarts.
# CODE_RUNNER_PROJECT_CONFIG_PATH=/workspace/project.yaml
# CODE_RUNNER_DB_PATH=/data/state.db
# CODE_RUNNER_EXECUTION_PROFILE_PATH=/workspace/execution-profile.yaml

# Langfuse (local observability stack — server auth)
LANGFUSE_NEXTAUTH_SECRET=
LANGFUSE_SALT=

# Langfuse SDK credentials (create in the Langfuse UI under Settings > API keys)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
# Override if not running on the default Docker Compose network
# LANGFUSE_HOST=http://langfuse:3000

# Langfuse trace retention (days). Enforces the ~180-day tier from Spec §11.2.
# Set on the Langfuse service; traces older than this are deleted automatically.
LANGFUSE_DEFAULT_PROJECT_RETENTION_DAYS=180

# Frontend build-time var — override if the API is not served at /api
# VITE_API_BASE_URL=/api
